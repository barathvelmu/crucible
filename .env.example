# Copy to .env and fill in. The .env file is gitignored.

# --- Option A: AI Studio (free tier, fastest to start) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-aistudio-api-key-here

# --- Option B: Vertex AI (enterprise; comment out Option A if you use this) ---
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Crucible toggles ---
# Run the scripted offline model (no key needed). Set to 1 to force offline.
CRUCIBLE_OFFLINE=0
# Per-role model overrides (defaults are gemini-2.5-flash for free-tier use).
# CRUCIBLE_JUDGE_MODEL=gemini-2.5-pro
